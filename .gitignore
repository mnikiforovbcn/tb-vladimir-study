# Python environment
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.uv/
uv-cache/

# Derived / generated data and outputs (regenerated by the pipeline, not source of truth)
Data/processed/
reports/*
!reports/.gitkeep

# Quarto render output left next to the .qmd source (cli.py moves the real
# copy into reports/<run_date>/ above; this guards against a stray manual
# `quarto render` in report/ getting committed again -- see the
# report/descriptive_report.html history-rewrite incident).
report/*.html
report/*.md

# Notebook checkpoints
.ipynb_checkpoints/

# Editor / OS
.DS_Store
.idea/
.vscode/
.vs/
.obsidian/
.claude/

# Test/coverage artifacts
.pytest_cache/
.coverage
htmlcov/
